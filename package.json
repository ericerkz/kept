{
  "name": "keep",
  "version": "1.3",
  "scripts": {
    "ng": "ng",
    "start": "concurrently \"npm run api\" \"npm run client\"",
    "client": "set NG_SASS_VERBOSE_DEPRECATIONS=0&& ng serve --host 0.0.0.0 --port 6767 --proxy-config proxy.conf.json",
    "api": "nodemon --no-deprecation server/server.js",
    "build": "ng build && npm run purgecss",
    "purgecss": "purgecss -c purgecss.config.js",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "analyze": "webpack-bundle-analyzer dist/keep/stats.json"
  },
  "private": true,
  "engines": {
    "node": ">=24 <25",
    "npm": ">=10"
  },
  "dependencies": {
    "@angular/animations": "^21.2.12",
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/platform-browser": "^21.2.12",
    "@angular/platform-browser-dynamic": "^21.2.12",
    "@angular/router": "^21.2.12",
    "@popperjs/core": "^2.11.5",
    "@types/jszip": "^3.4.0",
    "adm-zip": "^0.5.16",
    "bricks.js": "^1.8.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "jszip": "^3.10.1",
    "multer": "^2.1.1",
    "node-snackbar": "^0.1.16",
    "otplib": "^13.4.0",
    "qrcode": "^1.5.4",
    "rxjs": "~7.5.0",
    "sqlite3": "^6.0.1",
    "timepicker-ui": "^4.3.0",
    "tslib": "^2.3.0",
    "unzipper": "^0.12.3",
    "web-push": "^3.6.7",
    "ws": "^8.20.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.10",
    "@angular/cli": "~21.2.10",
    "@angular/compiler-cli": "^21.2.12",
    "@types/jasmine": "~4.0.0",
    "jasmine-core": "~4.1.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.0.0",
    "karma-jasmine-html-reporter": "~1.7.0",
    "nodemon": "^3.1.9",
    "purgecss": "^4.1.3",
    "typescript": "~5.9.3",
    "webpack-bundle-analyzer": "^4.6.1"
  }
}
